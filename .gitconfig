[user]
  name = Andrew Dollard
  email = "andrewdollard@gmail.com"
[color]
  branch = auto
  diff = auto
  interactive = auto
  status = auto
[core]
  editor = "vim"
  excludesfile = /Users/andrew/.gitignore_global
[alias]
  cm = "commit"
  co = "checkout"
  ds = "diff --staged"
  plom = "pull origin master"
  psom = "push origin master"
  last = "log -1 HEAD"
  subup = "submodule foreach git pull origin master"
  lol = "log --graph --decorate --pretty=oneline --abbrev-commit --all"
  ls = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate
  ll = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --numstat
  hist = log --graph --abbrev-commit --pretty=format:'%C(red)%h%C(reset) - %s %C(green)(%cr) %C(blue)<%an>%C(magenta)%d%C(reset)’'
[push]
  default = upstream
