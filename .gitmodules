[submodule "vim_dotfiles"]
	path = vim_dotfiles
	url = https://github.com/braintreeps/vim_dotfiles.git
[submodule ".oh-my-zsh"]
	path = .oh-my-zsh
	url = ./.oh-my-zsh
[submodule ".scm_breeze"]
	path = .scm_breeze
	url = ./.scm_breeze
[submodule "tmux-battery"]
	path = tmux-battery
	url = ./.tmux/plugins/tmux-battery
[submodule "tmux-sensible"]
	path = tmux-sensible
	url = ./.tmux/plugins/tmux-sensible
[submodule "tmux-themepack"]
	path = tmux-themepack
	url = ./.tmux/plugins/tmux-themepack
[submodule ".tmux/plugins/tmux-battery"]
	path = .tmux/plugins/tmux-battery
	url = ./.tmux/plugins/tmux-battery
[submodule ".tmux/plugins/tmux-sensible"]
	path = .tmux/plugins/tmux-sensible
	url = ./.tmux/plugins/tmux-sensible
[submodule ".tmux/plugins/tmux-themepack"]
	path = .tmux/plugins/tmux-themepack
	url = ./.tmux/plugins/tmux-themepack
